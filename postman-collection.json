		{
			"name": "GET-all-orders-success",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response body contains the array of orders\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.eql(true);",
							"    pm.expect(jsonData).to.have.property(\"orders\");",
							"    pm.expect(jsonData.orders).to.be.an(\"array\");",
							"    pm.expect(jsonData).to.have.property(\"count\");",
							"});",
							"",
							"pm.test(\"Every order has all of its expected fields\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.count > 0) {",
							"        jsonData.orders.forEach(order => {",
							"            pm.expect(order).to.have.property(\"id\");",
							"            pm.expect(order).to.have.property(\"customerEmail\");",
							"            pm.expect(order).to.have.property(\"items\");",
							"            pm.expect(order).to.have.property(\"totalPrice\");",
							"            pm.expect(order).to.have.property(\"status\");",
							"        });",
							"    }",
							"});",
							"",
							"pm.test(\"The number of orders is the same as the size of the orders array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.count).to.eql(jsonData.orders.length);",
							"});",
							"",
							"pm.test(\"Validating a performant retrieval of all orders is less than 2000ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(2000);",
							"});",
							""
						],
						"type": "text/javascript"
					}
				}
			],

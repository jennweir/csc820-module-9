		{
			"name": "POST-create-order",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Store orderId for collection variable in other tests\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.collectionVariables.set(\"orderId\", jsonData.order.id);",
							"});",
							"",
							"pm.test(\"Response body contains order information\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.eql(true);",
							"    pm.expect(jsonData).to.have.property(\"order\");",
							"    pm.expect(jsonData.order.id).to.be.a(\"number\");",
							"    pm.expect(jsonData.order.customerEmail).to.eql(\"johndoe@email.com\");",
							"    pm.expect(jsonData.order.status).to.eql(\"Pending\");",
							"});",
							"",
							"pm.test(\"Response contains email confirmation\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.notification.emailSent).to.eql(true);",
							"    pm.expect(jsonData.notification.to).to.eql(\"johndoe@email.com\");",
							"});",
							"",
							"pm.test(\"Response time accounts for email sending (2000ms)\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.above(2000);",
							"});",
							"",
							"pm.test(\"Content-Type header is application/json\", function () {",
							"    pm.response.to.have.header(\"Content-Type\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
